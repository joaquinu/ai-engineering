# Postgres Connection
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=rag
POSTGRES_USER=rag
POSTGRES_PASSWORD=rag

# RAG Service Configuration
# Pipeline type: simple, postgres, chroma, qdrant, hybrid, conversational
RAG_PIPELINE_TYPE=postgres

# Collection name for storing embeddings
RAG_COLLECTION_NAME=acme_docs_tfidf

# Embedder type: tfidf, sentence_transformers, bow, bm25
RAG_EMBEDDER_TYPE=tfidf

# Generator type: simple, claude, openai
RAG_GENERATOR_TYPE=claude

# RAG Parameters
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=50
RAG_TOP_K=5

# Global Retrieval Augmentation Features (work with any pipeline type)
# use_reranker: Re-rank results with Cohere reranker (requires CO_API_KEY)
RAG_USE_RERANKER=false
# use_hyde: Use hypothetical document expansion with LLM (requires ANTHROPIC_API_KEY)
RAG_USE_HYDE=false
# verbose: Print debug information
RAG_VERBOSE=false

# Hybrid Pipeline Parameters (only used when RAG_PIPELINE_TYPE=hybrid)
# sparse_embedder: Keyword-based embedding (bm25, tfidf)
RAG_HYBRID_SPARSE_EMBEDDER=bm25
# dense_embedder: Semantic embedding (sentence_transformers)
RAG_HYBRID_DENSE_EMBEDDER=sentence_transformers
# rrf_k: Reciprocal rank fusion parameter (higher = more results considered)
RAG_HYBRID_RRF_K=60

# API Keys
ANTHROPIC_API_KEY=your-anthropic-api-key-here
CO_API_KEY=your-cohere-api-key-here
